[debug] [2026-03-22T19:55:28.473Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/myapptest-9106d/rulesets {"name":"projects/myapptest-9106d/rulesets/c07fbb11-ac31-4396-bdc3-94bce3342201","source":{"files":[{"content":"rules_version = '2';\n\nservice firebase.storage {\n  match /b/{bucket}/o {\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function isManager() {\n      return isSignedIn()\n        && (\n          request.auth.token.email == \"admin@gmail.com\"\n          || request.auth.token.email == \"djumajadot6@gmail.com\"\n        );\n    }\n\n    function isAllowedDocument() {\n      return request.resource != null\n        && request.resource.size < 15 * 1024 * 1024\n        && request.resource.contentType.matches('^(application/pdf|image/.*)$');\n    }\n\n    match /driver-documents/{driverId}/{fileName} {\n      allow read: if isManager() || (isSignedIn() && request.auth.uid == driverId);\n      allow write: if isManager() && isAllowedDocument();\n    }\n  }\n}\n","name":"storage.rules"}]},"createTime":"2026-03-22T19:55:28.361599Z","metadata":{"services":["firebase.storage"]}}
