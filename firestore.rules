rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasUserProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isLegacyAdmin() {
      return isSignedIn()
        && request.auth.token.email == "admin@gmail.com";
    }

    function isManager() {
      return isAdmin() || isCoManager();
    }

    function isAdmin() {
      return isLegacyAdmin()
        || (
          hasUserProfile()
          && currentUserRole() == "admin"
        );
    }

    function isCoManager() {
      return hasUserProfile() && currentUserRole() == "co_manager";
    }

    function isDriver() {
      return hasUserProfile() && currentUserRole() == "driver";
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOwnPayment() {
      return isSignedIn() && resource.data.driverId == request.auth.uid;
    }

    function isOwnDriverDocument() {
      return isSignedIn() && resource.data.driverId == request.auth.uid;
    }

    function isSelfProfileUpdate(userId) {
      return isSelf(userId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["displayName", "email", "updatedAt"])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role;
    }

    function isCoManagerVisibleUser(userId) {
      return isCoManager() && (isSelf(userId) || resource.data.role == "driver");
    }

    function isCoManagerDriverCreate(userId) {
      return isCoManager()
        && request.resource.data.uid == userId
        && request.resource.data.role == "driver";
    }

    function isValidDriverSignatureUpdate() {
      return isDriver()
        && isOwnPayment()
        && (resource.data.driverSignature == null || resource.data.driverSignature == "")
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["driverSignature"])
        && request.resource.data.driverSignature is string
        && request.resource.data.driverSignature != "";
    }

    function isValidOwnPaymentCommentUpdate() {
      return isDriver()
        && isOwnPayment()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["comments"])
        && request.resource.data.comments is list;
    }

    match /users/{userId} {
      allow get: if isAdmin() || isCoManagerVisibleUser(userId) || isSelf(userId);
      allow list: if isAdmin() || isCoManagerVisibleUser(userId);
      allow create: if isAdmin() || isCoManagerDriverCreate(userId);
      allow update: if isAdmin() || isSelfProfileUpdate(userId);
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow get: if isManager() || isOwnPayment();
      allow list: if isManager() || (isDriver() && isOwnPayment());
      allow create: if isManager();
      allow update: if isManager() || isValidDriverSignatureUpdate() || isValidOwnPaymentCommentUpdate();
      allow delete: if false;
    }

    match /driverDocuments/{documentId} {
      allow get: if isManager() || isOwnDriverDocument();
      allow list: if isManager() || (isDriver() && isOwnDriverDocument());
      allow create, update, delete: if isManager();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
