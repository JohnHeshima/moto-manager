[debug] [2026-03-22T20:20:33.470Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/myapptest-9106d/rulesets {"name":"projects/myapptest-9106d/rulesets/529c9a2c-062c-47b6-9166-74cb30a5aff7","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function hasUserProfile() {\n      return isSignedIn()\n        && exists(/databases/$(database)/documents/users/$(request.auth.uid));\n    }\n\n    function currentUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    function isLegacyAdmin() {\n      return isSignedIn()\n        && request.auth.token.email == \"admin@gmail.com\";\n    }\n\n    function isManager() {\n      return isLegacyAdmin()\n        || (\n          hasUserProfile()\n          && (currentUserRole() == \"admin\" || currentUserRole() == \"co_manager\")\n        );\n    }\n\n    function isDriver() {\n      return hasUserProfile() && currentUserRole() == \"driver\";\n    }\n\n    function isSelf(userId) {\n      return isSignedIn() && request.auth.uid == userId;\n    }\n\n    function isOwnPayment() {\n      return isSignedIn() && resource.data.driverId == request.auth.uid;\n    }\n\n    function isOwnDriverDocument() {\n      return isSignedIn() && resource.data.driverId == request.auth.uid;\n    }\n\n    function isSelfProfileUpdate(userId) {\n      return isSelf(userId)\n        && request.resource.data.diff(resource.data).changedKeys().hasOnly([\"displayName\", \"email\", \"updatedAt\"])\n        && request.resource.data.uid == resource.data.uid\n        && request.resource.data.role == resource.data.role;\n    }\n\n    function isValidDriverSignatureUpdate() {\n      return isDriver()\n        && isOwnPayment()\n        && (resource.data.driverSignature == null || resource.data.driverSignature == \"\")\n        && request.resource.data.diff(resource.data).changedKeys().hasOnly([\"driverSignature\"])\n        && request.resource.data.driverSignature is string\n        && request.resource.data.driverSignature != \"\";\n    }\n\n    match /users/{userId} {\n      allow get: if isManager() || isSelf(userId);\n      allow list: if isManager();\n      allow create: if isManager();\n      allow update: if isManager() || isSelfProfileUpdate(userId);\n      allow delete: if isManager();\n    }\n\n    match /payments/{paymentId} {\n      allow get: if isManager() || isOwnPayment();\n      allow list: if isManager() || (isDriver() && isOwnPayment());\n      allow create: if isManager();\n      allow update: if isManager() || isValidDriverSignatureUpdate();\n      allow delete: if false;\n    }\n\n    match /driverDocuments/{documentId} {\n      allow get: if isManager() || isOwnDriverDocument();\n      allow list: if isManager() || (isDriver() && isOwnDriverDocument());\n      allow create, update, delete: if isManager();\n    }\n\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-03-22T20:20:33.306511Z","metadata":{"services":["cloud.firestore"]}}
