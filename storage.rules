rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isManager() {
      return isSignedIn()
        && (
          request.auth.token.email == "admin@gmail.com"
          || request.auth.token.email == "djumajadot6@gmail.com"
        );
    }

    function isAllowedDocument() {
      return request.resource != null
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('^(application/pdf|image/.*)$');
    }

    match /driver-documents/{driverId}/{fileName} {
      allow read: if isManager() || (isSignedIn() && request.auth.uid == driverId);
      allow write: if isManager() && isAllowedDocument();
    }
  }
}
