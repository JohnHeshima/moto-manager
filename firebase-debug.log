[debug] [2026-03-22T21:25:13.953Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/myapptest-9106d/rulesets {"name":"projects/myapptest-9106d/rulesets/1398ca7c-1e12-4f18-808f-b1cdfd7e5ad2","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function hasUserProfile() {\n      return isSignedIn()\n        && exists(/databases/$(database)/documents/users/$(request.auth.uid));\n    }\n\n    function currentUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    function isLegacyAdmin() {\n      return isSignedIn()\n        && request.auth.token.email == \"admin@gmail.com\";\n    }\n\n    function isManager() {\n      return isAdmin() || isCoManager();\n    }\n\n    function isAdmin() {\n      return isLegacyAdmin()\n        || (\n          hasUserProfile()\n          && currentUserRole() == \"admin\"\n        );\n    }\n\n    function isCoManager() {\n      return hasUserProfile() && currentUserRole() == \"co_manager\";\n    }\n\n    function isDriver() {\n      return hasUserProfile() && currentUserRole() == \"driver\";\n    }\n\n    function isSelf(userId) {\n      return isSignedIn() && request.auth.uid == userId;\n    }\n\n    function isOwnPayment() {\n      return isSignedIn() && resource.data.driverId == request.auth.uid;\n    }\n\n    function isOwnDriverDocument() {\n      return isSignedIn() && resource.data.driverId == request.auth.uid;\n    }\n\n    function isSelfProfileUpdate(userId) {\n      return isSelf(userId)\n        && request.resource.data.diff(resource.data).changedKeys().hasOnly([\"displayName\", \"email\", \"updatedAt\"])\n        && request.resource.data.uid == resource.data.uid\n        && request.resource.data.role == resource.data.role;\n    }\n\n    function isCoManagerVisibleUser(userId) {\n      return isCoManager() && (isSelf(userId) || resource.data.role == \"driver\");\n    }\n\n    function isCoManagerDriverCreate(userId) {\n      return isCoManager()\n        && request.resource.data.uid == userId\n        && request.resource.data.role == \"driver\";\n    }\n\n    function isValidDriverSignatureUpdate() {\n      return isDriver()\n        && isOwnPayment()\n        && (resource.data.driverSignature == null || resource.data.driverSignature == \"\")\n        && request.resource.data.diff(resource.data).changedKeys().hasOnly([\"driverSignature\"])\n        && request.resource.data.driverSignature is string\n        && request.resource.data.driverSignature != \"\";\n    }\n\n    function isValidOwnPaymentCommentUpdate() {\n      return isDriver()\n        && isOwnPayment()\n        && request.resource.data.diff(resource.data).changedKeys().hasOnly([\"comments\"])\n        && request.resource.data.comments is list;\n    }\n\n    match /users/{userId} {\n      allow get: if isAdmin() || isCoManagerVisibleUser(userId) || isSelf(userId);\n      allow list: if isAdmin() || isCoManagerVisibleUser(userId);\n      allow create: if isAdmin() || isCoManagerDriverCreate(userId);\n      allow update: if isAdmin() || isSelfProfileUpdate(userId);\n      allow delete: if isAdmin();\n    }\n\n    match /payments/{paymentId} {\n      allow get: if isManager() || isOwnPayment();\n      allow list: if isManager() || (isDriver() && isOwnPayment());\n      allow create: if isManager();\n      allow update: if isManager() || isValidDriverSignatureUpdate() || isValidOwnPaymentCommentUpdate();\n      allow delete: if false;\n    }\n\n    match /driverDocuments/{documentId} {\n      allow get: if isManager() || isOwnDriverDocument();\n      allow list: if isManager() || (isDriver() && isOwnDriverDocument());\n      allow create, update, delete: if isManager();\n    }\n\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-03-22T21:25:13.770095Z","metadata":{"services":["cloud.firestore"]}}
